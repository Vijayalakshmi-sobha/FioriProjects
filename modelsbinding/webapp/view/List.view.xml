<mvc:View controllerName="com.applexus.modelsbinding.controller.List"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

    <List headerText="Fruits">

        <items>

                <DisplayListItem label="Name" value="Apple" ></DisplayListItem>
                
                <StandardListItem title="Mango" 
                                 icon="https://cdn3.iconfinder.com/data/icons/fruit-lineal-color/512/mango-1024.png" 
                                 info="Mango is the national fruit of india"
                                 description="A mango is an edible stone fruit produced by the tropical tree Mangifera indica. "
                                 iconInset="true">
                
                        <!-- if icon is not here we can use avatar aggregation instead -->

                        <!-- <avatar >
                            <Avatar src="https://cdn3.iconfinder.com/data/icons/fruit-lineal-color/512/mango-1024.png"></Avatar>    
                        </avatar> -->
                </StandardListItem>

                <InputListItem label="Enter Details" 
                               labelTextDirection="LTR">
                
                    <content>

                        <VBox >
                            <Label text="Enter Name"/>
                            <Input width="300px"></Input>
                        </VBox>
                        <VBox >
                            <Label text="Enter fruit"/>
                            <TextArea width="400px"></TextArea>
                        </VBox>
                        <VBox >
                            <Button text="Submit"></Button>
                        </VBox>
                    </content>
    
                </InputListItem>
                
                <FeedListItem
                    sender="Vijaya"
                    text="Purchased Some Good Apple."
                    timestamp="2026-03-17 10:30"
                    type="Detail"
                    icon="data:image/webp;base64,">
    
                    
                </FeedListItem>
        
                <ActionListItem text="Add to Cart" />
                <ActionListItem text="Remove From Cart" />

                
        <CustomListItem>
            <content>
                <HBox alignItems="Center" justifyContent="SpaceBetween">
                    <items>
                                <Avatar 
                                    src="https://cdn3.iconfinder.com/data/icons/fruit-lineal-color/512/apple-1024.png" 
                                    displayShape="Circle" />
                                
                                <VBox>
                                        <Text text="Apple" />
                                        <Text text="Sweet and crunchy" />
                                </VBox>
                        <Button text="Add" type="Emphasized"/>
                    </items>
                </HBox>
            </content>
        </CustomListItem>
 

        </items>

    </List>

    <Table headerText="Column List ">
    <columns>
        <Column>
            <Text text="Fruit" />
        </Column>
        <Column>
            <Text text="Taste" />
        </Column>
    </columns>

    <items>
        <ColumnListItem>
            <cells>
                <Text text="Apple" />
                <Text text="Crisp and fresh" />
            </cells>
        </ColumnListItem>

        <ColumnListItem>
            <cells>
                <Text text="Mango" />
                <Text text="Sweet and juicy" />
            </cells>
        </ColumnListItem>
    </items>
</Table>


    </Page>
</mvc:View>